# Email Configuration for Contact Form Notifications
# To enable email notifications, fill in these values:

# Your Gmail address
EMAIL_USER=your-email@gmail.com

# Gmail App Password (not your regular password)
# Get this from: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-app-password

# Email where notifications should be sent
OWNER_EMAIL=adnanshora180899@gmail.com

# Server port (optional, default is 3000)
PORT=3000
